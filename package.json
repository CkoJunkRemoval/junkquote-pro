{
  "name": "junkquote-pro",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "vercel-build": "node scripts/vercel-build.mjs",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "typecheck": "tsc --noEmit --pretty false",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "npm run test:unit && npm run test:integration",
    "test:db:provision": "node scripts/provision-test-db.mjs",
    "test:db:reset": "node scripts/test-db-reset.mjs",
    "test:db:prepare": "node scripts/test-db-prepare.mjs",
    "test:db:generate": "prisma generate",
    "verify:vercel-build": "node scripts/verify-vercel-build.mjs",
    "assets:migrate": "tsx scripts/migrate-private-assets.ts",
    "assets:verify": "tsx scripts/verify-asset-backup.ts",
    "worker:once": "tsx scripts/worker-once.ts",
    "beta:verify": "tsx scripts/beta-verify.ts",
    "cap:sync": "cap sync",
    "cap:android": "cap sync android",
    "cap:ios": "cap sync ios",
    "android:apk": "cap build android --androidreleasetype APK",
    "android:bundle": "cap build android --androidreleasetype AAB"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/app": "^8.1.1",
    "@capacitor/browser": "^8.0.4",
    "@capacitor/camera": "^8.2.1",
    "@capacitor/core": "^8.4.2",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.4.2",
    "@capacitor/push-notifications": "^8.1.2",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.2",
    "@prisma/adapter-pg": "^7.9.0",
    "@prisma/client": "^7.9.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.23.0",
    "next": "16.2.11",
    "next-auth": "^5.0.0-beta.31",
    "pg": "^8.22.0",
    "prisma": "^7.9.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "stripe": "^22.3.2",
    "tailwind-merge": "^3.6.0"
  },
  "overrides": {
    "postcss": "8.5.19",
    "next": {
      "sharp": "0.35.0"
    }
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.2",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
