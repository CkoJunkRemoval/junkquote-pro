generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  MANAGER
  ESTIMATOR
  CREW_LEADER
  CREW_MEMBER
  OFFICE
}

enum EstimateStatus {
  Draft
  Ready
  Sent
  Approved
  Declined
  Scheduled
  Completed
  Archived
}

enum SignatureMethod {
  PublicLink
  TeamDevice
}

model Company {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  email     String?
  website   String?
  active    Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  settings  CompanySettings?
  users     User[]
  customers Customer[]
  estimates Estimate[]

  @@map("companies")
}

model CompanySettings {
  id            String   @id @default(uuid())

  companyId     String   @unique
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  timezone      String   @default("America/New_York")
  currency      String   @default("USD")
  businessHours String?
  taxRate       Float    @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("company_settings")
}

model User {
  id           String   @id @default(uuid())

  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  firstName    String
  lastName     String

  email        String   @unique
  passwordHash String

  role         UserRole

  active       Boolean  @default(true)
  lastLogin    DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([companyId])

  @@map("users")
}

model Customer {
  id         String   @id @default(uuid())

  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  firstName  String
  lastName   String
  phone      String
  email      String?
  notes      String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  properties Property[]
  estimates  Estimate[]

  @@index([companyId])
  @@index([lastName])

  @@map("customers")
}

model Property {
  id             String   @id @default(uuid())

  customerId     String
  customer       Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  nickname       String?

  address        String
  city           String
  state          String
  zip            String

  gateCode       String?
  accessNotes    String?
  parkingNotes   String?
  dangerousPets  String?
  hoaNotes       String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  estimates Estimate[]

  @@index([customerId])

  @@map("properties")
}

model Estimate {
  id         String         @id @default(uuid())

  companyId  String
  company    Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)

  customerId String
  customer   Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)

  propertyId String
  property   Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  status     EstimateStatus @default(Draft)

  pricingSubtotal Float @default(0)
  pricingLabor    Float @default(0)
  pricingDisposal Float @default(0)
  pricingDiscount Float @default(0)
  pricingTotal    Float @default(0)
  currentStep     Int   @default(1)

  sentAt                  DateTime?
  sentByEmailAt           DateTime?
  sentBySmsAt             DateTime?
  approvalToken           String?   @unique
  approvalTokenExpiresAt  DateTime?
  signatureData           String?
  signedAt                DateTime?
  signerName              String?
  signatureMethod         SignatureMethod?

  jobSites   JobSite[]

  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([companyId])
  @@index([customerId])
  @@index([propertyId])

  @@map("estimates")
}

model JobSite {
  id            String   @id @default(uuid())

  estimateId    String
  estimate      Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  name          String
  status        String   @default("not-started")
  customerNotes String   @default("")
  crewNotes     String   @default("")
  internalNotes String   @default("")
  sortOrder     Int

  items         EstimateItem[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([estimateId])
  @@map("job_sites")
}

model EstimateItem {
  id            String   @id @default(uuid())

  jobSiteId     String
  jobSite       JobSite  @relation(fields: [jobSiteId], references: [id], onDelete: Cascade)

  itemId        String
  name          String
  category      String
  quantity      Int      @default(1)
  notes         String   @default("")
  priceOverride Float?
  sortOrder     Int

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([jobSiteId, itemId])
  @@index([jobSiteId])
  @@map("estimate_items")
}
