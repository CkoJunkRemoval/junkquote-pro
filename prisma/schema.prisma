}

model AdminImpersonation {
  id            String    @id @default(uuid())
  companyId     String?
  company       Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  adminUserId   String
  administrator User      @relation("AdminImpersonationAdministrator", fields: [adminUserId], references: [id], onDelete: Restrict)
  targetUserId  String
  targetUser    User      @relation("AdminImpersonationTarget", fields: [targetUserId], references: [id], onDelete: Restrict)
  reason        String
  ipHash        String?
  userAgent     String?
  startedAt     DateTime  @default(now())
  expiresAt     DateTime
  endedAt       DateTime?

  @@index([companyId, startedAt])
  @@index([adminUserId, endedAt, expiresAt])
  @@map("admin_impersonations")
}

model AdminPasswordResetToken {
  id               String    @id @default(uuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash        String    @unique
  expiresAt        DateTime
  usedAt           DateTime?
  createdByAdminId String
  createdByAdmin   User      @relation("AdminPasswordResetCreator", fields: [createdByAdminId], references: [id], onDelete: Restrict)
  createdAt        DateTime  @default(now())

  @@index([userId, expiresAt])
  @@map("admin_password_reset_tokens")
}

model Crew {
  id           String          @id @default(uuid())
  companyId    String
  company      Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name         String
  color        String?
  active       Boolean         @default(true)
  members      CrewMember[]
  assignments  JobAssignment[]
  servicePlans ServicePlan[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([companyId])
  @@map("crews")
}

model ServicePlan {
  id                     String                @id @default(uuid())
  companyId              String
  company                Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customerId             String
  customer               Customer              @relation(fields: [customerId], references: [id], onDelete: Cascade)
  propertyId             String?
  property               Property?             @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  name                   String
  description            String?
  status                 ServicePlanStatus     @default(Draft)
  recurrenceType         RecurrenceType
  interval               Int                   @default(1)
  daysOfWeek             Int[]
  dayOfMonth             Int?
  shortMonthBehavior     ShortMonthBehavior    @default(LastDay)
  startDate              DateTime
  endDate                DateTime?
  preferredStartTime     String?
  preferredEndTime       String?
  defaultDurationMinutes Int?
  assignedCrewId         String?
  assignedCrew           Crew?                 @relation(fields: [assignedCrewId], references: [id], onDelete: SetNull)
  employeeAssignments    ServicePlanEmployee[]
  defaultJobNotes        String?
  defaultInternalNotes   String?
  defaultPrice           Float?
  autoCreateJobs         Boolean               @default(false)
  autoCreateInvoices     Boolean               @default(false)
  nextRunAt              DateTime?
  lastRunAt              DateTime?
  createdByUserId        String
  createdByUser          User                  @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  jobs                   Job[]
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  @@index([companyId, status, nextRunAt])
  @@index([companyId, customerId])
  @@map("service_plans")
}

model ServicePlanEmployee {
  servicePlanId String
  servicePlan   ServicePlan @relation(fields: [servicePlanId], references: [id], onDelete: Cascade)
  employeeId    String
  employee      Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@id([servicePlanId, employeeId])
  @@map("service_plan_employees")
}

model CrewMember {
  crewId     String
  crew       Crew     @relation(fields: [crewId], references: [id], onDelete: Cascade)
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  isLead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@id([crewId, employeeId])
  @@map("crew_members")
}

model JobAssignment {
  id         String    @id @default(uuid())
  companyId  String
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobId      String
  job        Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  crewId     String?
  crew       Crew?     @relation(fields: [crewId], references: [id], onDelete: Cascade)
  assignedAt DateTime  @default(now())
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([jobId, employeeId])
  @@unique([jobId, crewId])
  @@index([companyId])
  @@map("job_assignments")
}

model JobSite {
  id String @id @default(uuid())

  estimateId String
  estimate   Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  name          String
  status        String @default("not-started")
  customerNotes String @default("")
  crewNotes     String @default("")
  internalNotes String @default("")
  sortOrder     Int

  items          EstimateItem[]
  photos         JobPhoto[]
  revisionPhotos EstimatePhoto[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([estimateId])
  @@map("job_sites")
}

model EstimateItem {
  id String @id @default(uuid())

  jobSiteId String
  jobSite   JobSite @relation(fields: [jobSiteId], references: [id], onDelete: Cascade)

  itemId        String
  libraryItemId String?
  libraryItem   ItemLibrary? @relation(fields: [libraryItemId], references: [id], onDelete: SetNull)
  name          String
  category      String
  quantity      Int    @default(1)
  notes         String @default("")
  priceOverride Float?
  basePrice       Float   @default(0)
  disposalFee     Float   @default(0)
  laborHours      Float   @default(0)
  weightClass     String  @default("Medium")
  estimatedVolume Float  @default(0)
  crewRequirement Int    @default(1)
  recyclable        Boolean @default(false)
  donationEligible  Boolean @default(false)
  hazardous          Boolean @default(false)
  refrigerant        Boolean @default(false)
  electronics        Boolean @default(false)
  mattress           Boolean @default(false)
  tire               Boolean @default(false)
  appliance          Boolean @default(false)
  constructionDebris Boolean @default(false)
  yardWaste          Boolean @default(false)
  requiresDisassembly      Boolean @default(false)
  requiresSpecialEquipment Boolean @default(false)
  pricingManuallyEdited    Boolean @default(false)
  sortOrder     Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([jobSiteId, itemId])
  @@index([jobSiteId])
  @@index([libraryItemId])
  @@map("estimate_items")
}

model BackgroundJob {
  id                    String                 @id @default(uuid())
  companyId             String
  company               Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type                  BackgroundJobType
  status                BackgroundJobStatus    @default(Pending)
  priority              BackgroundJobPriority  @default(Normal)
  payload               Json
  idempotencyKey        String?
  attempts              Int                    @default(0)
  maxAttempts           Int                    @default(3)
  lastError             String?
  availableAt           DateTime               @default(now())
  startedAt             DateTime?
  completedAt           DateTime?
  createdByUserId       String?
  createdByUser         User?                  @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  communicationDelivery CommunicationDelivery?

  @@unique([companyId, type, idempotencyKey])
  @@index([status, availableAt, priority, createdAt])
  @@index([companyId, status, createdAt])
  @@map("background_jobs")
}

model CommunicationDelivery {
  id                String                      @id @default(uuid())
  companyId         String
  company           Company                     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  backgroundJobId   String?                     @unique
  backgroundJob     BackgroundJob?              @relation(fields: [backgroundJobId], references: [id], onDelete: SetNull)
  idempotencyKey    String
  provider          String
  channel           String
  recipientHash     String
  status            CommunicationDeliveryStatus @default(Pending)
  providerMessageId String?                     @unique
  requestId         String?
  sentAt            DateTime?
  deliveredAt       DateTime?
  failedAt          DateTime?
  bouncedAt         DateTime?
  rejectedAt        DateTime?
  lastErrorCode     String?
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt

  @@unique([companyId, idempotencyKey])
  @@index([companyId, status, createdAt])
  @@map("communication_deliveries")
}

model ProviderWebhookEvent {
  id                String   @id @default(uuid())
  companyId         String?
  company           Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  provider          String
  providerEventId   String   @unique
  eventType         String
  providerMessageId String?
  occurredAt        DateTime
  processedAt       DateTime @default(now())
  createdAt         DateTime @default(now())

  @@index([provider, providerMessageId])
  @@map("provider_webhook_events")
}

model ReminderSchedule {
  id              String       @id @default(uuid())
  companyId       String
  company         Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type            ReminderType
  targetId        String?
  enabled         Boolean      @default(true)
  scheduledFor    DateTime
  payload         Json
  lastEnqueuedAt  DateTime?
  createdByUserId String?
  createdByUser   User?        @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([companyId, type, enabled, scheduledFor])
  @@map("reminder_schedules")
}
