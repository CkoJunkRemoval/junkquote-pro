generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  MANAGER
  ESTIMATOR
  CREW_LEADER
  CREW_MEMBER
  OFFICE
}

enum MembershipRole {
  Owner
  Admin
  Manager
  Office
  Crew
}

enum MembershipStatus {
  Active
  Suspended
}

enum EstimateStatus {
  Draft
  Sent
  Viewed
  Approved
  Scheduled
  InProgress
  Completed
  Invoiced
  Paid
  Declined
  Expired
  Canceled
}

enum EstimateEventCategory {
  Lifecycle
  Estimate
  Customer
  Property
  Items
  Pricing
  Photos
  Notes
  Communication
  Scheduling
  Job
  Invoice
  Payment
  Revision
}

enum EstimateEventActorType {
  System
  Employee
  Customer
  PlatformAdmin
}

enum EstimateEventVisibility {
  Internal
  Customer
  Both
}

enum SignatureMethod {
  PublicLink
  TeamDevice
}

enum JobStatus {
  Unscheduled
  Scheduled
  InProgress
  Completed
  Cancelled
}

enum DispatchProgress {
  NotStarted
  EnRoute
  Arrived
  Loading
}

enum FieldJobStage {
  Scheduled
  EnRoute
  Arrived
  Working
  Loading
  Cleanup
  Completed
  ReadyForInvoice
}

enum FieldChangeOrderType {
  AdditionalItems
  AdditionalLabor
  ExtraDumpFees
  UnexpectedObstacle
}

enum FieldChangeOrderStatus {
  Draft
  Submitted
  ManagerReview
  CustomerApprovalRequired
  Pending
  Approved
  Declined
  Rejected
  ChangesRequested
}

enum FieldTimeEventType {
  ClockIn
  BreakStart
  BreakEnd
  ClockOut
}

enum FieldOfflineOperationStatus {
  Pending
  Applied
  Conflict
  Failed
}

enum JobPriority {
  Low
  Normal
  High
  Urgent
}

enum InvoiceStatus {
  Draft
  Sent
  Viewed
  Partial
  Paid
  Overdue
  Void
  Cancelled
}

enum PaymentMethod {
  Cash
  Check
  CreditCard
  DebitCard
  ACH
  CashApp
  ApplePay
  Other
}

enum PaymentProvider {
  Manual
  Stripe
  Square
}

enum ProviderPaymentStatus {
  Pending
  Captured
  Failed
  Refunded
}

enum FinancialAdjustmentType {
  Credit
  WriteOff
  Adjustment
}

enum ReconciliationStatus {
  Pending
  Matched
  Duplicate
  FailedCapture
  Orphaned
  Ignored
}

enum JobPhotoCategory {
  Before
  During
  After
  Damage
  AdditionalItems
  Receipt
  Disposal
  Other
}

enum EmployeeRole {
  Owner
  Manager
  Estimator
  CrewLead
  CrewMember
  Office
}

enum EmployeeStatus {
  Active
  Inactive
}

enum BackgroundJobType {
  SendCommunication
  GenerateEstimatePdf
  GenerateInvoicePdf
  GenerateReceipt
  CleanupFiles
  ScheduledReminder
  WebhookDelivery
  Future
  ServicePlanGeneration
}

enum ServicePlanStatus {
  Draft
  Active
  Paused
  Completed
  Cancelled
}

enum RecurrenceType {
  Weekly
  Monthly
  CustomInterval
}

enum ShortMonthBehavior {
  LastDay
  Skip
}

enum CustomerPortalAccessStatus {
  Active
  Revoked
}

enum CustomerPortalTokenPurpose {
  SignIn
  EmailVerification
  Future
}

enum BackgroundJobStatus {
  Pending
  Running
  Completed
  Failed
  Cancelled
}

enum BackgroundJobPriority {
  Low
  Normal
  High
  Critical
}

enum CommunicationDeliveryStatus {
  Pending
  Sent
  Delivered
  Failed
  Bounced
  Rejected
}

enum ReminderType {
  EstimateReminder
  UpcomingJob
  OutstandingInvoice
}

enum SmartPricingDecisionType {
  Accepted
  PartiallyAdjusted
  Ignored
  Unavailable
}

model Company {
  id                            String  @id @default(uuid())
  name                          String
  legalName                     String  @default("JunkQuote Pro")
  displayName                   String  @default("JunkQuote Pro")
  phone                         String?
  email                         String?
  website                       String?
  addressLine1                  String?
  addressLine2                  String?
  city                          String?
  state                         String?
  postalCode                    String?
  logoUrl                       String?
  primaryColor                  String?
  secondaryColor                String?
  invoicePrefix                 String  @default("INV")
  estimatePrefix                String  @default("EST")
  defaultTaxRate                Float   @default(0)
  defaultPaymentTermsDays       Int     @default(30)
  defaultEstimateExpirationDays Int     @default(30)
  defaultMinimumCharge          Float   @default(0)
  timezone                      String  @default("America/New_York")
  currencyCode                  String  @default("USD")
  active                        Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  settings                CompanySettings?
  users                   User[]
  memberships             CompanyMembership[]
  customers               Customer[]
  estimates               Estimate[]
  estimateTimelineEvents  EstimateTimelineEvent[]
  estimateActivityItems   EstimateActivityFeedItem[]
  jobs                    Job[]
  invoices                Invoice[]
  payments                Payment[]
  jobPhotos               JobPhoto[]
  employees               Employee[]
  crews                   Crew[]
  assignments             JobAssignment[]
  backgroundJobs          BackgroundJob[]
  reminderSchedules       ReminderSchedule[]
  pricingHistory          PricingHistory[]
  smartPricingDecisions   SmartPricingDecision[]
  createdRefunds          Refund[]
  pricingOutcomes         PricingOutcome[]
  pricingProfiles         PricingProfile[]
  itemLibrary             ItemLibrary[]
  servicePlans            ServicePlan[]
  portalAccesses          CustomerPortalAccess[]
  auditEvents             AuditEvent[]
  communicationDeliveries CommunicationDelivery[]
  providerWebhookEvents   ProviderWebhookEvent[]
  fleetAssets             FleetAsset[]
  maintenanceRecords      FleetMaintenance[]
  disposalRecords         DisposalRecord[]
  timeEntries             EmployeeTimeEntry[]
  financialAdjustments    FinancialAdjustment[]
  reconciliationRuns      PaymentReconciliationRun[]
  reconciliationItems     PaymentReconciliationItem[]
  arReminderPolicies      ArReminderPolicy[]
  fieldChecklistItems     FieldChecklistItem[]
  fieldChangeOrders       FieldChangeOrder[]
  fieldSignatures         JobCompletionSignature[]
  fieldTimeEvents         FieldTimeEvent[]
  fieldOfflineOperations  FieldOfflineOperation[]
  subscription            CompanySubscription?
  subscriptionHistory     SubscriptionHistory[]
  stripeWebhookEvents     StripeWebhookEvent[]
  featureFlags            FeatureFlag[]
  systemErrors            SystemErrorEvent[]
  notifications           SystemNotification[]
  usageMetrics            CompanyUsageDaily[]
  impersonations          AdminImpersonation[]
  onboarding              CompanyOnboarding?
  serviceAreaRules        ServiceAreaRule[]

  @@map("companies")
}

model CompanySettings {
  id String @id @default(uuid())

  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  timezone                        String  @default("America/New_York")
  currency                        String  @default("USD")
  businessHours                   String?
  taxRate                         Float   @default(0)
  smartPricingEnabled             Boolean @default(false)
  smartPricingMinimumSampleSize   Int     @default(5)
  smartPricingConfidenceThreshold Int     @default(60)
  smartPricingUseLaborHistory     Boolean @default(true)
  smartPricingUseDisposalHistory  Boolean @default(true)
  smartPricingUseTravelHistory    Boolean @default(false)
  portalShowAssignedCrew          Boolean @default(false)
  serviceRadiusMiles              Float   @default(25)
  defaultLaborRate                Float   @default(0)
  defaultDumpFee                  Float   @default(0)
  heavyItemSurcharge              Float   @default(0)
  appliancePrice                  Float   @default(0)
  yardDebrisPrice                 Float   @default(0)
  constructionDebrisPrice         Float   @default(0)
  approvalExpirationDays          Int     @default(30)
  dateFormat                      String  @default("MM/DD/YYYY")
  communicationSenderName         String?
  communicationReplyTo            String?
  estimateEmailTemplate           String?
  invoiceEmailTemplate            String?
  approvalEmailTemplate           String?
  pdfBrandingEnabled              Boolean @default(true)
  portalBrandingEnabled           Boolean @default(true)
  itemLibraryDefaults             Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("company_settings")
}

model CompanyOnboarding {
  id                String    @id @default(uuid())
  companyId         String    @unique
  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  currentStep       Int       @default(1)
  completedSections String[]  @default([])
  skippedAt         DateTime?
  completedAt       DateTime?
  dismissedAt       DateTime?
  demoDataIds       Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("company_onboarding")
}

model ServiceAreaRule {
  id             String   @id @default(uuid())
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  kind           String
  value          String
  travelZone     String?
  distanceCharge Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([companyId, kind, value])
  @@index([companyId, travelZone])
  @@map("service_area_rules")
}

model User {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  firstName String?
  lastName  String?

  email        String @unique
  passwordHash String

  role UserRole

  active                     Boolean                   @default(true)
  lastLogin                  DateTime?
  platformAdmin              Boolean                   @default(false)
  sessionVersion             Int                       @default(0)
  devices                    UserDevice[]
  adminPasswordResetTokens   AdminPasswordResetToken[]
  administeredImpersonations AdminImpersonation[]      @relation("AdminImpersonationAdministrator")
  targetedImpersonations     AdminImpersonation[]      @relation("AdminImpersonationTarget")
  createdAdminResetTokens    AdminPasswordResetToken[] @relation("AdminPasswordResetCreator")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships              CompanyMembership[]
  createdBackgroundJobs    BackgroundJob[]
  createdReminderSchedules ReminderSchedule[]
  smartPricingDecisions    SmartPricingDecision[]
  createdRefunds           Refund[]
  createdServicePlans      ServicePlan[]
  employee                 Employee?
  auditEvents              AuditEvent[]

  @@index([companyId])
  @@map("users")
}

model CompanyMembership {
  id           String           @id @default(uuid())
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId    String
  company      Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role         MembershipRole   @default(Owner)
  status       MembershipStatus @default(Active)
  billingAdmin Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([userId, companyId])
  @@index([companyId, status])
  @@map("company_memberships")
}

model Customer {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  firstName String
  lastName  String
  phone     String
  email     String?
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  properties     Property[]
  estimates      Estimate[]
  jobs           Job[]
  invoices       Invoice[]
  servicePlans   ServicePlan[]
  portalAccesses CustomerPortalAccess[]

  @@index([companyId])
  @@index([lastName])
  @@map("customers")
}

model Property {
  id String @id @default(uuid())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  nickname     String?
  propertyType String?

  address           String
  addressLine2      String?
  city              String
  state             String
  zip               String
  country           String   @default("US")
  normalizedAddress String?
  latitude          Float?
  longitude         Float?

  gateCode      String?
  accessNotes   String?
  parkingNotes  String?
  hazardNotes   String?
  notes         String?
  serviceArea   String?
  dangerousPets String?
  hoaNotes      String?
  active         Boolean  @default(true)
  archivedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  estimates    Estimate[]
  jobs         Job[]
  invoices     Invoice[]
  servicePlans ServicePlan[]

  @@index([customerId])
  @@index([customerId, active])
  @@index([normalizedAddress])
  @@index([city])
  @@map("properties")
}

model Estimate {
  id            String  @id @default(uuid())
  displayNumber String? @unique

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  pricingProfileId String
  pricingProfile   PricingProfile @relation(fields: [pricingProfileId], references: [id], onDelete: Restrict)

  status EstimateStatus @default(Draft)

  pricingSubtotal     Float  @default(0)
  pricingLabor        Float  @default(0)
  pricingDisposal     Float  @default(0)
  pricingDiscount     Float  @default(0)
  pricingTotal        Float  @default(0)
  estimatedLaborHours Float?
  estimatedLaborCost  Float?
  currentStep         Int    @default(1)

  sentAt                 DateTime?
  sentByEmailAt          DateTime?
  sentBySmsAt            DateTime?
  approvalToken          String?          @unique
  approvalTokenExpiresAt DateTime?
  signatureData          String?
  signedAt               DateTime?
  signerName             String?
  signatureMethod        SignatureMethod?

  revisionNumber Int        @default(0)
  revisionRootId String?
  revisionRoot   Estimate?  @relation("EstimateRevisions", fields: [revisionRootId], references: [id], onDelete: Restrict)
  revisions      Estimate[] @relation("EstimateRevisions")

  jobSites             JobSite[]
  revisionPhotos       EstimatePhoto[]
  job                  Job?
  invoice              Invoice?
  pricingHistory       PricingHistory[]
  smartPricingDecision SmartPricingDecision?
  timelineEvents       EstimateTimelineEvent[]
  activityFeedItems    EstimateActivityFeedItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([revisionRootId, revisionNumber])
  @@index([companyId])
  @@index([customerId])
  @@index([propertyId])
  @@index([pricingProfileId])
  @@index([revisionRootId])
  @@map("estimates")
}

model PricingProfile {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name            String
  description     String?
  active          Boolean @default(true)
  defaultProfile  Boolean @default(false)
  minimumCharge   Float   @default(0)
  tripFee         Float   @default(0)
  laborRate       Float   @default(0)
  dumpFee         Float   @default(0)
  mileageRate     Float   @default(0)
  fuelSurcharge   Float   @default(0)
  defaultCrewSize Int     @default(1)
  taxEnabled      Boolean @default(false)
  taxRate         Float   @default(0)
  currency        String  @default("USD")
  displayOrder    Int     @default(0)

  estimates     Estimate[]
  itemOverrides PricingProfileItemOverride[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([companyId, active])
  @@index([companyId, defaultProfile])
  @@map("pricing_profiles")
}

model ItemLibrary {
  id        String @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  category     String
  name         String
  description  String?
  active       Boolean @default(true)
  displayOrder Int     @default(0)

  basePrice       Float @default(0)
  disposalFee     Float @default(0)
  laborHours      Float @default(0.25)
  weightClass     String @default("Medium")
  estimatedVolume Float @default(0)

  recyclable        Boolean @default(false)
  donationEligible  Boolean @default(false)
  hazardous          Boolean @default(false)
  refrigerant        Boolean @default(false)
  electronics        Boolean @default(false)
  mattress           Boolean @default(false)
  tire               Boolean @default(false)
  appliance          Boolean @default(false)
  constructionDebris Boolean @default(false)
  yardWaste          Boolean @default(false)

  requiresTwoPeople        Boolean @default(false)
  requiresDisassembly      Boolean @default(false)
  requiresSpecialEquipment Boolean @default(false)
  notes                    String?

  profileOverrides PricingProfileItemOverride[]
  estimateItems    EstimateItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([companyId, category])
  @@index([companyId, active])
  @@index([companyId, displayOrder])
  @@map("item_library")
}

model PricingProfileItemOverride {
  id               String @id @default(uuid())
  pricingProfileId String
  pricingProfile   PricingProfile @relation(fields: [pricingProfileId], references: [id], onDelete: Cascade)
  itemLibraryId    String
  itemLibrary      ItemLibrary @relation(fields: [itemLibraryId], references: [id], onDelete: Cascade)

  basePrice       Float?
  disposalFee     Float?
  laborHours      Float?
  crewRequirement Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([pricingProfileId, itemLibraryId])
  @@index([pricingProfileId])
  @@index([itemLibraryId])
  @@map("pricing_profile_item_overrides")
}

model EstimateTimelineEvent {
  id               String                    @id @default(uuid())
  eventType        String
  estimateId       String
  estimate         Estimate                  @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  companyId        String
  company          Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  actor            String
  category         EstimateEventCategory     @default(Estimate)
  actorType        EstimateEventActorType    @default(System)
  actorId          String?
  actorDisplayName String
  title            String
  summary          String
  visibility       EstimateEventVisibility   @default(Internal)
  searchText       String                    @default("")
  jobId            String?
  timestamp        DateTime                  @default(now())
  metadata         Json?
  attachments      EstimateEventAttachment[]

  @@index([estimateId, timestamp, id])
  @@index([companyId, timestamp, id])
  @@index([companyId, category, timestamp, id])
  @@index([companyId, actorId, timestamp, id])
  @@index([companyId, visibility, timestamp, id])
  @@index([companyId, jobId, timestamp, id])
  @@map("estimate_timeline_events")
}

model EstimateEventAttachment {
  id            String                @id @default(uuid())
  eventId       String
  event         EstimateTimelineEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  referenceType String
  referenceId   String
  displayName   String
  url           String?
  metadata      Json?
  createdAt     DateTime              @default(now())

  @@index([eventId])
  @@index([referenceType, referenceId])
  @@map("estimate_event_attachments")
}

model EstimateActivityFeedItem {
  id         String   @id @default(uuid())
  estimateId String
  estimate   Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  actor      String
  message    String
  eventType  String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([estimateId, createdAt])
  @@index([companyId, createdAt])
  @@map("estimate_activity_feed_items")
}

enum FleetAssetType {
  Truck
  Trailer
  Equipment
}

enum FleetAssetStatus {
  Active
  Maintenance
  OutOfService
  Retired
}

enum DisposalCategory {
  Landfill
  Donation
  Recycling
  ScrapMetal
  HazardousWaste
  Other
}

enum TimeEntryType {
  Work
  PTO
}

enum SubscriptionPlan {
  Starter
  Professional
  Business
}

enum SubscriptionStatus {
  Trialing
  Active
  PastDue
  Unpaid
  Canceled
  Incomplete
  Paused
}

model EstimatePhoto {
  id              String           @id @default(uuid())
  estimateId      String
  estimate        Estimate         @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  jobSiteId       String?
  jobSite         JobSite?         @relation(fields: [jobSiteId], references: [id], onDelete: SetNull)
  category        JobPhotoCategory @default(Other)
  fileUrl         String
  thumbnailUrl    String?
  fileName        String
  mimeType        String
  fileSize        Int
  caption         String?
  customerVisible Boolean          @default(false)
  sortOrder       Int
  takenAt         DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([estimateId, category, sortOrder])
  @@index([jobSiteId])
  @@map("estimate_photos")
}

model Job {
  id        String  @id @default(uuid())
  jobNumber String? @unique

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  estimateId String   @unique
  estimate   Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  status                JobStatus               @default(Unscheduled)
  dispatchProgress      DispatchProgress        @default(NotStarted)
  fieldStage            FieldJobStage           @default(Scheduled)
  fieldVersion          Int                     @default(0)
  priority              JobPriority             @default(Normal)
  enRouteAt             DateTime?
  arrivedAt             DateTime?
  completedAt           DateTime?
  departureLatitude     Float?
  departureLongitude    Float?
  arrivalLatitude       Float?
  arrivalLongitude      Float?
  completionLatitude    Float?
  completionLongitude   Float?
  travelDurationMinutes Int?
  crewConfirmedAt       DateTime?
  scheduledStart        DateTime?
  scheduledEnd          DateTime?
  truck                 String?
  crewNotes             String                  @default("")
  customerNotes         String                  @default("")
  completionNotes       String                  @default("")
  actualLaborHours      Float?
  actualLaborCost       Float?
  actualDisposalCost    Float?
  actualTravelCost      Float?
  otherActualCost       Float?
  actualCostNotes       String                  @default("")
  finalInvoiceAmount    Float?
  assignedFleetAssetId  String?
  assignedFleetAsset    FleetAsset?             @relation(fields: [assignedFleetAssetId], references: [id], onDelete: SetNull)
  disposalRecords       DisposalRecord[]
  invoice               Invoice?
  photos                JobPhoto[]
  assignments           JobAssignment[]
  fieldChecklistItems   FieldChecklistItem[]
  fieldChangeOrders     FieldChangeOrder[]
  completionSignature   JobCompletionSignature?
  fieldTimeEvents       FieldTimeEvent[]
  offlineOperations     FieldOfflineOperation[]
  pricingHistory        PricingHistory[]
  pricingOutcome        PricingOutcome?
  servicePlanId         String?
  servicePlan           ServicePlan?            @relation(fields: [servicePlanId], references: [id], onDelete: SetNull)
  servicePlanOccurrence DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([servicePlanId, servicePlanOccurrence])
  @@index([companyId, fieldStage, scheduledStart])
  @@index([customerId])
  @@index([propertyId])
  @@index([scheduledStart])
  @@map("jobs")
}

model PricingHistory {
  id                  String   @id @default(uuid())
  companyId           String
  company             Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  estimateId          String
  estimate            Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  jobId               String
  job                 Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  customerId          String
  area                String
  item                String
  quantity            Int
  cubicYards          Float
  laborHours          Float
  disposalCost        Float
  dumpFees            Float
  travelDistance      Float?
  travelTime          Float?
  finalQuotedPrice    Float
  finalCollectedPrice Float
  discount            Float
  profitEstimate      Float
  propertyType        String?
  createdAt           DateTime @default(now())

  @@unique([jobId, item, area])
  @@index([companyId, item, createdAt])
  @@index([companyId, createdAt])
  @@map("pricing_history")
}

model SmartPricingDecision {
  id                   String                   @id @default(uuid())
  companyId            String
  company              Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  estimateId           String                   @unique
  estimate             Estimate                 @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  recommendedPrice     Float
  confidenceScore      Int
  historicalSampleSize Int
  manualPrice          Float
  appliedPrice         Float?
  accepted             Boolean?
  decision             SmartPricingDecisionType @default(Unavailable)
  finalQuotedAmount    Float?
  difference           Float?
  decidedAt            DateTime?
  actingUserId         String?
  actingUser           User?                    @relation(fields: [actingUserId], references: [id], onDelete: SetNull)
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  @@index([companyId, createdAt])
  @@map("smart_pricing_decisions")
}

model Invoice {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  customerId String
