generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  MANAGER
  ESTIMATOR
  CREW_LEADER
  CREW_MEMBER
  OFFICE
}

enum MembershipRole {
  Owner
  Admin
  Manager
  Office
  Crew
}

enum MembershipStatus {
  Active
  Suspended
}

enum EstimateStatus {
  Draft
  Ready
  Sent
  Approved
  Declined
  Scheduled
  Completed
  Archived
}

enum SignatureMethod {
  PublicLink
  TeamDevice
}

enum JobStatus {
  Unscheduled
  Scheduled
  InProgress
  Completed
  Cancelled
}

enum InvoiceStatus {
  Draft
  Sent
  Partial
  Paid
  Overdue
  Cancelled
}

enum PaymentMethod {
  Cash
  Check
  CreditCard
  DebitCard
  ACH
  CashApp
  ApplePay
  Other
}

enum JobPhotoCategory {
  Before
  During
  After
  Damage
  Disposal
  Other
}

enum EmployeeRole {
  Owner
  Manager
  CrewLead
  CrewMember
  Office
}

enum EmployeeStatus {
  Active
  Inactive
}

model Company {
  id        String   @id @default(uuid())
  name      String
  legalName String   @default("JunkQuote Pro")
  displayName String @default("JunkQuote Pro")
  phone     String?
  email     String?
  website   String?
  addressLine1 String?
  addressLine2 String?
  city String?
  state String?
  postalCode String?
  logoUrl String?
  primaryColor String?
  secondaryColor String?
  invoicePrefix String @default("INV")
  estimatePrefix String @default("EST")
  defaultTaxRate Float @default(0)
  defaultPaymentTermsDays Int @default(30)
  defaultEstimateExpirationDays Int @default(30)
  defaultMinimumCharge Float @default(0)
  timezone String @default("America/New_York")
  currencyCode String @default("USD")
  active    Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  settings  CompanySettings?
  users     User[]
  memberships CompanyMembership[]
  customers Customer[]
  estimates Estimate[]
  jobs      Job[]
  invoices  Invoice[]
  payments  Payment[]
  jobPhotos JobPhoto[]
  employees Employee[]
  crews     Crew[]
  assignments JobAssignment[]

  @@map("companies")
}

model CompanySettings {
  id            String   @id @default(uuid())

  companyId     String   @unique
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  timezone      String   @default("America/New_York")
  currency      String   @default("USD")
  businessHours String?
  taxRate       Float    @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("company_settings")
}

model User {
  id           String   @id @default(uuid())

  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  firstName    String?
  lastName     String?

  email        String   @unique
  passwordHash String

  role         UserRole

  active       Boolean  @default(true)
  lastLogin    DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships  CompanyMembership[]

  @@index([companyId])

  @@map("users")
}

model CompanyMembership {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId String
  company   Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role      MembershipRole   @default(Owner)
  status    MembershipStatus @default(Active)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([userId, companyId])
  @@index([companyId, status])
  @@map("company_memberships")
}

model Customer {
  id         String   @id @default(uuid())

  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  firstName  String
  lastName   String
  phone      String
  email      String?
  notes      String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  properties Property[]
  estimates  Estimate[]
  jobs       Job[]
  invoices   Invoice[]

  @@index([companyId])
  @@index([lastName])

  @@map("customers")
}

model Property {
  id             String   @id @default(uuid())

  customerId     String
  customer       Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  nickname       String?

  address        String
  city           String
  state          String
  zip            String

  gateCode       String?
  accessNotes    String?
  parkingNotes   String?
  dangerousPets  String?
  hoaNotes       String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  estimates Estimate[]
  jobs      Job[]
  invoices  Invoice[]

  @@index([customerId])

  @@map("properties")
}

model Estimate {
  id         String         @id @default(uuid())
  displayNumber String?     @unique

  companyId  String
  company    Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)

  customerId String
  customer   Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)

  propertyId String
  property   Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  status     EstimateStatus @default(Draft)

  pricingSubtotal Float @default(0)
  pricingLabor    Float @default(0)
  pricingDisposal Float @default(0)
  pricingDiscount Float @default(0)
  pricingTotal    Float @default(0)
  currentStep     Int   @default(1)

  sentAt                  DateTime?
  sentByEmailAt           DateTime?
  sentBySmsAt             DateTime?
  approvalToken           String?   @unique
  approvalTokenExpiresAt  DateTime?
  signatureData           String?
  signedAt                DateTime?
  signerName              String?
  signatureMethod         SignatureMethod?

  jobSites   JobSite[]
  job        Job?
  invoice    Invoice?

  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([companyId])
  @@index([customerId])
  @@index([propertyId])

  @@map("estimates")
}

model Job {
  id              String    @id @default(uuid())

  companyId       String
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  estimateId      String    @unique
  estimate        Estimate  @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  customerId      String
  customer        Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  propertyId      String
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  status          JobStatus @default(Unscheduled)
  scheduledStart  DateTime?
  scheduledEnd    DateTime?
  crewNotes       String    @default("")
  customerNotes   String    @default("")
  completionNotes String    @default("")
  invoice         Invoice?
  photos          JobPhoto[]
  assignments     JobAssignment[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([companyId])
  @@index([customerId])
  @@index([propertyId])
  @@index([scheduledStart])
  @@map("jobs")
}

model Invoice {
  id            String        @id @default(uuid())

  companyId     String
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)

  customerId    String
  customer      Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)

  propertyId    String
  property      Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  jobId         String?       @unique
  job           Job?          @relation(fields: [jobId], references: [id], onDelete: SetNull)

  estimateId    String        @unique
  estimate      Estimate      @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  invoiceNumber Int           @unique
  displayNumber String?       @unique
  subtotal      Float
  tax           Float         @default(0)
  discounts     Float         @default(0)
  total         Float
  balanceDue    Float
  status        InvoiceStatus @default(Draft)
  dueDate       DateTime?
  issuedDate    DateTime?
  paidDate      DateTime?
  notes         String        @default("")
  payments      Payment[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([companyId])
  @@index([customerId])
  @@index([propertyId])
  @@index([status])
  @@map("invoices")
}

model Payment {
  id              String        @id @default(uuid())

  companyId       String
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)

  invoiceId       String
  invoice         Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  amount          Float
  method          PaymentMethod
  referenceNumber String?
  paymentDate     DateTime
  notes           String        @default("")

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([companyId])
  @@index([invoiceId])
  @@map("payments")
}

model JobPhoto {
  id           String           @id @default(uuid())
  companyId    String
  company      Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobId        String
  job          Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobSiteId    String?
  jobSite      JobSite?         @relation(fields: [jobSiteId], references: [id], onDelete: SetNull)
  category     JobPhotoCategory @default(Other)
  fileUrl      String
  thumbnailUrl String?
  fileName     String
  mimeType     String
  fileSize     Int
  caption      String?
  sortOrder    Int
  takenAt      DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([companyId])
  @@index([jobId, category, sortOrder])
  @@index([jobSiteId])
  @@map("job_photos")
}

model Employee {
  id         String         @id @default(uuid())
  companyId  String
  company    Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  firstName  String
  lastName   String
  email      String?
  phone      String?
  role       EmployeeRole
  status     EmployeeStatus @default(Active)
  hourlyRate Float?
  color      String?
  notes      String?
  crewMembers CrewMember[]
  assignments JobAssignment[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  @@index([companyId])
  @@map("employees")
}

model Crew {
  id         String          @id @default(uuid())
  companyId  String
  company    Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name       String
  color      String?
  active     Boolean         @default(true)
  members    CrewMember[]
  assignments JobAssignment[]
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  @@index([companyId])
  @@map("crews")
}

model CrewMember {
  crewId     String
  crew       Crew     @relation(fields: [crewId], references: [id], onDelete: Cascade)
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  isLead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  @@id([crewId, employeeId])
  @@map("crew_members")
}

model JobAssignment {
  id         String    @id @default(uuid())
  companyId  String
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobId      String
  job        Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  crewId     String?
  crew       Crew?     @relation(fields: [crewId], references: [id], onDelete: Cascade)
  assignedAt DateTime  @default(now())
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  @@unique([jobId, employeeId])
  @@unique([jobId, crewId])
  @@index([companyId])
  @@map("job_assignments")
}

model JobSite {
  id            String   @id @default(uuid())

  estimateId    String
  estimate      Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  name          String
  status        String   @default("not-started")
  customerNotes String   @default("")
  crewNotes     String   @default("")
  internalNotes String   @default("")
  sortOrder     Int

  items         EstimateItem[]
  photos        JobPhoto[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([estimateId])
  @@map("job_sites")
}

model EstimateItem {
  id            String   @id @default(uuid())

  jobSiteId     String
  jobSite       JobSite  @relation(fields: [jobSiteId], references: [id], onDelete: Cascade)

  itemId        String
  name          String
  category      String
  quantity      Int      @default(1)
  notes         String   @default("")
  priceOverride Float?
  sortOrder     Int

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([jobSiteId, itemId])
  @@index([jobSiteId])
  @@map("estimate_items")
}
