# Core production infrastructure (required; provider-specific credentials below apply to the selected provider)
DATABASE_URL=postgresql://user:password@localhost:5432/junkquote_pro_dev
DATABASE_URL_TEST=postgresql://user:password@localhost:5432/junkquote_pro_test
TEST_DATABASE_ALLOWED_HOSTS=localhost,127.0.0.1
TEST_DATABASE_ALLOWED_NAMES=junkquote_pro_test
AUTH_SECRET=replace-with-at-least-32-random-characters
AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Used only while syncing/building the hosted Capacitor container.
CAPACITOR_SERVER_URL=https://junkquoteprohq.com
PRIVATE_ASSET_STORAGE_DRIVER=local
PRIVATE_ASSET_STORAGE_ROOT=.data/private-assets
EMAIL_PROVIDER=console
EMAIL_FROM=no-reply@example.test
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
SUPABASE_STORAGE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=
# Optional features. Leave a complete group blank to disable it gracefully.
BACKGROUND_WORKERS_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_BUSINESS=
BILLING_TRIAL_DAYS=14
BILLING_GRACE_DAYS=7
BILLING_REQUIRE_CARD_AT_SIGNUP=false
PLATFORM_ADMIN_EMAIL=
# Optional override; an audited built-in CSP is used when blank.
CONTENT_SECURITY_POLICY=
KV_REST_API_URL=
KV_REST_API_TOKEN=
PUSH_NOTIFICATIONS_ENABLED=false
MFA_ISSUER=
